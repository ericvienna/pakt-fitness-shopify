<section class="hero">
  <div class="hero-bg">
    {%- if section.settings.video -%}
      {{- section.settings.video | video_tag: autoplay: true, muted: true, loop: true, playsinline: true, controls: false -}}
    {%- else -%}
      <video autoplay muted loop playsinline>
        <source src="{{ 'hero-video.mp4' | asset_url }}" type="video/mp4">
      </video>
    {%- endif -%}
    {%- if section.settings.image -%}
      <img
        src="{{ section.settings.image | image_url: width: 2000 }}"
        alt="{{ section.settings.image.alt | escape | default: shop.name }}"
        width="2000"
        loading="eager"
        {% if section.settings.video %}style="display:none;"{% endif %}
      >
    {%- endif -%}
  </div>
  <div class="hero-content">
    <p class="hero-eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="hero-title">{{ section.settings.heading }}</h1>
    <p class="hero-subtitle">{{ section.settings.subtitle }}</p>
    <a href="{{ section.settings.cta_link }}" class="btn btn-primary">{{ section.settings.cta_text }}</a>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Hero video",
      "info": "Upload a video in Settings → Files, then select it here. If empty, the default bundled video plays."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback image",
      "info": "Shown while video loads or if no video is set."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Founding Member Merch"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "First to Sweat."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Limited-run pieces for the crew who believed first. Once they're gone, they're gone."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Shop the Drop"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
