<section class="about-section">
  <div class="about-inner">

    {%- comment -%} ETHOS BLOCK {%- endcomment -%}
    <div class="about-ethos">
      <div class="about-ethos-text">
        <p class="about-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="about-headline">{{ section.settings.headline }}</h2>
        <p class="about-lead">{{ section.settings.lead }}</p>
        <p class="about-body">{{ section.settings.body }}</p>
      </div>

      <div class="about-stats">
        <div class="about-stat">
          <span class="about-stat-num">50</span>
          <span class="about-stat-label">Founding Spots</span>
        </div>
        <div class="about-stat">
          <span class="about-stat-num">2&times;</span>
          <span class="about-stat-label">Per Week, Minimum</span>
        </div>
        <div class="about-stat">
          <span class="about-stat-num">15&prime;</span>
          <span class="about-stat-label">Post-Sweat Social</span>
        </div>
      </div>
    </div>

    {%- comment -%} HOW IT WORKS {%- endcomment -%}
    <div class="about-process">
      <div class="about-process-header">
        <p class="about-eyebrow">The Process</p>
        <h2 class="about-headline">Simple to join.<br>Built to stay.</h2>
      </div>

      <div class="about-steps">
        <div class="about-step">
          <span class="about-step-num">01</span>
          <h3 class="about-step-title">Reserve Your Spot</h3>
          <p class="about-step-body">Secure your founding member rate before PAKT opens. Pre-sale pricing is exclusively available now — once the 50 spots are gone, this pricing disappears permanently.</p>
        </div>
        <div class="about-step">
          <span class="about-step-num">02</span>
          <h3 class="about-step-title">Find Your PAKT</h3>
          <p class="about-step-body">We match you with a crew and a coach based on your schedule, goals, and energy. As a founding member, you get first dibs before classes start filling up.</p>
        </div>
        <div class="about-step">
          <span class="about-step-num">03</span>
          <h3 class="about-step-title">Show Up. Stay.</h3>
          <p class="about-step-body">Train together at least twice a week. Track your progress. Build real bonds. Watch consistency become the thing that doesn't require willpower anymore.</p>
        </div>
      </div>
    </div>

    {%- comment -%} MANIFESTO {%- endcomment -%}
    <div class="about-manifesto">
      <p class="about-eyebrow">The Pakt</p>
      <h2 class="about-manifesto-text">{{ section.settings.manifesto }}</h2>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "About / Ethos",
  "settings": [
    {
      "type": "header",
      "content": "Ethos"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Difference"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Most gyms sell you a floor. We sell you a crew."
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead paragraph",
      "default": "In an increasingly isolated urban world, the gym should be more than a transaction. PAKT is built on the science of social fitness — where consistency isn't found through willpower, it's built through belonging."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body paragraph",
      "default": "Your PAKT trains together at least twice a week — same coach, same time, same crew. Real accountability. Trackable progress. Real bonds. Followed by a 15-minute coffee social, because the work doesn't stop when the workout does."
    },
    {
      "type": "header",
      "content": "Manifesto"
    },
    {
      "type": "textarea",
      "id": "manifesto",
      "label": "Manifesto text",
      "default": "We don't do motivation. We do showing up. We don't sell hype. We sell the person next to you who won't let you quit. This is PAKT. First to sweat. Last to quit."
    }
  ],
  "presets": [
    {
      "name": "About / Ethos"
    }
  ]
}
{% endschema %}
