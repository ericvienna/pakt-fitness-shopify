<section class="collection-section">
  <div class="collection-header">
    <h2>{{ collection.title }}</h2>
    {%- if collection.description != blank -%}
      <p style="color: var(--gold-dim); font-size: 14px; margin-top: 16px; max-width: 500px; margin-left: auto; margin-right: auto; line-height: 1.5;">
        {{ collection.description }}
      </p>
    {%- endif -%}
  </div>

  <div class="product-grid">
    {%- for product in collection.products -%}
      {% render 'product-card', product: product %}
    {%- else -%}
      <p style="color: var(--gold-dim); text-align: center; grid-column: 1 / -1;">No products yet. Check back soon.</p>
    {%- endfor -%}
  </div>
</section>
